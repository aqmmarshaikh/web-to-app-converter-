# =========================================================================
# AppForge Production Hardened Environment Configuration Template
# =========================================================================

# App Core Configuration
NODE_ENV=production
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Redis Cache & BullMQ Job Queue (Defaults to local Docker container name)
REDIS_URL=redis://redis:6379

# Firebase Client SDK Configuration (Required for Frontend Compilation)
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyYourApiKeyHere"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-app-domain.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="1:your-sender-id:web:your-app-id"

# Firebase Admin SDK Configuration (Required for Backend Database & Storage Queries)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-adminsdk.json"

# Keystore Signing Details (Fallback defaults to android debug key)
KEYSTORE_PATH=./keys/debug.keystore
KEYSTORE_PASSWORD=android
KEY_ALIAS=androiddebugkey
KEY_PASSWORD=android

# Performance & Security
MAX_BUILD_TIME_MS=300000
MAX_PROJECT_SIZE_MB=100
BUILD_CLEANUP_HOURS=24
MAX_CONCURRENT_BUILDS=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
